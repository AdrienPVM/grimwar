# Copy this file to .env.local and fill in values from Firebase Console
# Project settings → General → Your apps → SDK setup and configuration

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# App Check — reCAPTCHA v3 site key
# Firebase Console → Build → App Check → Apps → Register your web app → reCAPTCHA v3
VITE_RECAPTCHA_SITE_KEY=

# Firebase Local Emulator Suite — passer à `true` pour brancher l'app sur
# l'émulateur (Auth http://127.0.0.1:9099, Firestore 127.0.0.1:8080).
# Utilisé par `pnpm test:e2e` (cf. plan 13.5). NE JAMAIS activer en prod.
# Requiert Java/JRE 11+ pour lancer l'émulateur (`pnpm e2e:emulators`).
VITE_USE_FIREBASE_EMULATOR=false
