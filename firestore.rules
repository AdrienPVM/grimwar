rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════
    // Helpers
    // ═══════════════════════════════════════════════════════════

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // JALON 4.0.2 : `dmUserId` (singleton) remplacé par `gmIds: string[]`
    // (préparation co-MJ multiples — cf. décision JALON-4.0). L'helper accepte
    // tout signed-in dont l'UID figure dans la liste des MJ. `gmIds.size() >= 1`
    // est garanti par la rule de create + la rule d'update (qui empêche de
    // tomber à 0).
    function isDMOf(campaignId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/campaigns/$(campaignId))
        && request.auth.uid in get(/databases/$(database)/documents/campaigns/$(campaignId)).data.gmIds;
    }

    // JALON 4.0.2 : sous-collection `memberships/` renommée `members/` (cf.
    // décision JALON-4.0 — alignement avec le schéma Zod CampaignSchema). Un
    // MJ N'A PAS forcément de doc dans `members/` — la membership MJ est
    // sous-entendue par `gmIds[]` sur le doc parent.
    function isMemberOf(campaignId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/campaigns/$(campaignId)/members/$(request.auth.uid));
    }

    function memberRole(campaignId) {
      return get(/databases/$(database)/documents/campaigns/$(campaignId)/members/$(request.auth.uid)).data.role;
    }

    // DM of any campaign that the character has joined?
    // The character doc has `presentInCampaigns: string[]`.
    // We iterate via .hasAny (allowed in rules).
    function isDMOfAnyCampaignFor(character) {
      return character.presentInCampaigns is list
        && character.presentInCampaigns.size() > 0
        && character.presentInCampaigns.hasAny(getDMCampaignsForRequester());
    }

    // The set of campaigns the requesting user is DM of cannot be cheaply enumerated.
    // We rely on a different predicate: the character's owning user can write freely;
    // the DM check is done by reading EACH campaign in presentInCampaigns and seeing
    // if dmUserId matches. Use `someCampaignHasMeAsDM`.
    function someCampaignHasMeAsDM(character) {
      // Caller responsibility: presentInCampaigns must be ≤ 10 (Firestore array limit
      // for membership-style queries). For S2+ we add a Cloud Function for >10 campaigns.
      // For now, validate via iteration is not directly possible in rules;
      // we instead require the WRITER to pass a campaignId in a special way:
      // by writing through a Cloud Function for DM-authority edits.
      //
      // For S1 (no campaigns yet): only owners can write. Returns false.
      // For S2+: a Cloud Function checks DM authority and writes via Admin SDK.
      return false;
    }

    // ═══════════════════════════════════════════════════════════
    // /users/{userId}
    // ═══════════════════════════════════════════════════════════

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId)
        // Prevent client from setting subscription tier directly (only Cloud Function via Stripe webhook)
        && (!('tier' in request.resource.data) || request.resource.data.tier == resource.data.tier);
      allow delete: if isOwner(userId);

      // ── Characters ─────────────────────────────────────────────
      match /characters/{characterId} {
        // Read: owner OR co-member in a campaign where the character is also a member
        allow read: if isOwner(userId)
          || requestUserSharesACampaignWith(userId, characterId);

        // Write: owner only via direct client write.
        // DM-authority edits go through a Cloud Function (Admin SDK) post-S2.
        allow create: if isOwner(userId)
          && characterShapeOK(request.resource.data);
        allow update: if isOwner(userId)
          && characterShapeOK(request.resource.data);
        allow delete: if isOwner(userId);
      }

      // ── Custom content (DMG extracts, homebrew) ────────────────
      match /customContent/{type}/{contentId} {
        allow read, write: if isOwner(userId);
      }

      // ── Custom content packs (JALON 3B — option γ user-scoped)
      // Un doc par pack importé, shape `{meta, entities, importedAt}` —
      // service src/shared/lib/services/pack-storage.ts. La rule reste
      // owner-only ; pas de partage cross-user à ce stade (3D ajoutera
      // potentiellement un duplicate dans une campagne).
      match /customContentPacks/{packId} {
        allow read, write: if isOwner(userId);
      }

      // ── User-level sessions cache (rare; mostly campaign-scoped)
      match /sessions/{sessionId} {
        allow read, write: if isOwner(userId);
      }
    }

    function requestUserSharesACampaignWith(characterOwnerId, characterId) {
      // To check this cheaply, we use a denormalized field on the character:
      // character.presentInCampaigns: string[]
      // and we check that the request.auth.uid has a membership in any of those campaigns.
      // Without rule iteration, we approximate: the character doc must include the
      // requesting user's membership at the time of read.
      //
      // For simplicity in v1, this allows any authenticated user to read characters
      // referenced in their own memberships path. The client passes the campaignId
      // explicitly via a query, and rules can verify it via the path. Practical
      // implementation: we'll use a Cloud Function for cross-character reads
      // post-S2 to avoid rules complexity here.
      //
      // For S1 (no campaigns): only owner reads. Returns false.
      return false;
    }

    function characterShapeOK(data) {
      // Invariants minimaux anti-corruption. Validation détaillée côté Zod (client).
      //
      // Schéma multi-class verrouillé (CLAUDE.md + docs/DATA-MODEL.md) :
      //   - classes: [{ classId, subclassId, level, ...sous-choix SRD v2 }] (1..4 entrées)
      //   - totalLevel: somme dénormalisée (1..20)
      //   - primaryClassId: id de la classe principale
      //
      // schemaVersion 1 ET 2 sont acceptés en shape-only (plan 13.7 §0.3, option b).
      // La rule ne valide ni `ancestrySubChoices` ni les sous-choix de `classes[]`
      // — c'est Zod côté client + le wizard 13.8/13.9 qui imposent les sous-choix
      // SRD requis (« si Drakéide alors dragonAncestry ») avant le setDoc. Acté
      // 2026-05-17 : pas de durcissement (a) tant qu'on n'a pas de stratégie de
      // migration prod (cf. D5 + 13.7 §0.2 — pas de step de rattrapage UI).
      //
      // Cette fonction est appelée pour CREATE et pour UPDATE. Sémantique Firestore :
      //   - create : `data` = nouveau document complet → hasAll([...]) force la présence.
      //   - update : `data` = document MERGÉ (état actuel + patch), pas le patch seul.
      //     hasAll([...]) protège donc contre une update qui supprimerait une clé
      //     requise via deleteField() — comportement voulu.
      //   - Validation fine (types items, clés skills/saves, structure inventory…)
      //     reste côté Zod ; la rule garde uniquement la forme structurelle.
      return data.keys().hasAll([
          'name', 'status',
          'totalLevel', 'classes', 'primaryClassId',
          'ancestryId', 'backgroundId',
          'abilities', 'hp', 'schemaVersion'
        ])
        && data.status in ['alive', 'dead']
        && data.primaryClassId is string
        && data.totalLevel is int && data.totalLevel >= 1 && data.totalLevel <= 20
        && data.classes is list && data.classes.size() >= 1 && data.classes.size() <= 4
        && data.hp.current is int && data.hp.max is int
        && data.abilities.for is int && data.abilities.dex is int && data.abilities.con is int
        && data.abilities.int is int && data.abilities.sag is int && data.abilities.cha is int;
    }

    // ═══════════════════════════════════════════════════════════
    // /campaigns/{campaignId}
    // ═══════════════════════════════════════════════════════════

    match /campaigns/{campaignId} {
      // Read: any signed-in MJ or member.
      // JALON 4.0.4 fix : on lit directement `resource.data.gmIds` plutôt que
      // de passer par l'helper `isDMOf(campaignId)` qui faisait `get()` sur le
      // doc en cours d'évaluation. Firestore Rules ne supportent pas `get()`
      // sur le doc lui-même dans une opération `list`/query (Firestore le
      // traite comme une lookup et renvoie une "Null value error" parce que la
      // requête n'a pas encore résolu de doc-cible). `resource.data` exposant
      // directement les champs du doc, on évite le round-trip et le rule
      // s'applique uniformément aux get/list/collectionGroup. La branche
      // member garde son `exists()` sur la sous-collection (path différent du
      // doc en cours), qui passe pour les 3 opérations.
      allow read: if isSignedIn() && (
        request.auth.uid in resource.data.gmIds
        || exists(/databases/$(database)/documents/campaigns/$(campaignId)/members/$(request.auth.uid))
      );

      // Create: any signed-in user (they become MJ — must appear in gmIds).
      // JALON 4.0.2 — l'invariant `auth.uid in gmIds` remplace `dmUserId ==
      // auth.uid`. La taille de gmIds à la création est laissée libre côté
      // rules (Zod côté client impose min 1 / max 8).
      allow create: if isSignedIn()
        && request.resource.data.gmIds is list
        && request.auth.uid in request.resource.data.gmIds
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.status == 'active'
        && request.resource.data.schemaVersion is int;

      // Update: tout MJ existant peut écrire. Garde-fou : on n'autorise pas à
      // vider gmIds (toujours ≥ 1 MJ), ni à changer createdBy. La promotion en
      // co-MJ (arrayUnion sur gmIds) est donc autorisée tant que l'invariant
      // ≥ 1 MJ tient — c'est le pré-requis du sous-jalon 4C.
      allow update: if isDMOf(campaignId)
        && request.resource.data.gmIds is list
        && request.resource.data.gmIds.size() >= 1
        && request.resource.data.createdBy == resource.data.createdBy;
      allow delete: if isDMOf(campaignId);

      // ── Members ───────────────────────────────────────────────
      // JALON 4.0.2 : ex-`memberships/`. Doc ID = userId, payload aligné sur
      // `MembershipSchema` (Zod). Rôles `gm`|`member` (le spectateur a été
      // droppé en 4.0 — cf. décision JALON-4.0).
      match /members/{userId} {
        // Read: tout signed-in MJ ou membre de la campagne peut voir le roster.
        allow read: if isMemberOf(campaignId) || isDMOf(campaignId);

        // Create:
        //  - l'utilisateur lui-même (acceptation d'invite par code),
        //  - OU un MJ existant qui ajoute quelqu'un.
        // Contrainte : userId du payload doit correspondre au userId du doc ID
        // (anti-spoof). Rôle dans ['gm','member'].
        // JALON 4.0.6 : `exists(/campaigns/{cid})` empêche qu'un code orphelin
        // (campagne supprimée mais doc inviteCodes encore présent — race rare)
        // permette d'écrire dans une sous-collection fantôme. Sans ce check,
        // Firestore accepterait le write puisqu'une sous-collection n'exige
        // pas l'existence du parent. La rule de read côté `campaigns/{cid}`
        // refuserait ensuite la navigation post-join, laissant un doc member
        // orphelin imprononçable. La pré-condition est consommée par
        // `joinByCode` (4.0.3 → 4.0.6) qui traduit permission-denied en
        // `CampaignServiceError('campaign-not-found')`.
        allow create: if (isOwner(userId) || isDMOf(campaignId))
          && exists(/databases/$(database)/documents/campaigns/$(campaignId))
          && request.resource.data.userId == userId
          && request.resource.data.role in ['gm', 'member']
          && request.resource.data.schemaVersion is int;

        // Update:
        //  - MJ peut tout modifier (changer le rôle d'un membre, lier un
        //    characterId, etc.),
        //  - le user lui-même peut update son propre doc SAUF son rôle
        //    (anti self-promotion). Le characterId reste modifiable par le
        //    propriétaire (link/unlink de sa fiche).
        allow update: if isDMOf(campaignId)
          || (isOwner(userId)
              && request.resource.data.role == resource.data.role
              && request.resource.data.userId == resource.data.userId);

        // Delete: MJ only (kick) OU self (leave).
        allow delete: if isDMOf(campaignId) || isOwner(userId);
      }

      // ── Sessions ──────────────────────────────────────────────
      match /sessions/{sessionId} {
        allow read: if isMemberOf(campaignId);
        allow create, update, delete: if isDMOf(campaignId);
      }

      // ── Events ────────────────────────────────────────────────
      match /events/{eventId} {
        // Read: members can read events visible to them
        // (visibility filter applied client-side; rules allow members to read all,
        // we trust client to filter. Tightening this requires more denormalization.)
        allow read: if isMemberOf(campaignId)
          && (resource.data.visibility == 'all'
              || (resource.data.visibility == 'dm' && isDMOf(campaignId))
              || (resource.data.visibility == 'self'
                  && (resource.data.actorUserId == request.auth.uid
                      || resource.data.actorCharacterId in getMyCharacterIds(campaignId)
                      || resource.data.targetCharacterId in getMyCharacterIds(campaignId))));

        // Create: any member can log their own events; DM can log anything
        allow create: if isMemberOf(campaignId)
          && request.resource.data.actorUserId == request.auth.uid
          && request.resource.data.kind is string
          && request.resource.data.createdAt == request.time;

        // Events are immutable
        allow update: if false;
        allow delete: if isDMOf(campaignId);   // DM can prune very old events
      }

      // ── Campaign-scoped custom content ────────────────────────
      match /customContent/{type}/{contentId} {
        allow read: if isMemberOf(campaignId);
        allow write: if isDMOf(campaignId);
      }

      // ── Encounters ────────────────────────────────────────────
      match /encounters/{encounterId} {
        allow read: if isMemberOf(campaignId);
        allow create, update, delete: if isDMOf(campaignId);
      }

      // ── Maps ──────────────────────────────────────────────────
      // Read : DM (par défaut) OU membre — le DM n'a pas de doc
      // `memberships/{uid}` (cf. plan 13.13 et la rule de
      // `campaigns/{cid}` ligne 156 qui combine déjà les deux), donc
      // restreindre à `isMemberOf` seul exclurait le DM de ses propres
      // cartes. CHANTIER D phase 2 D.6 — fix bug rules.
      match /maps/{mapId} {
        allow read: if isDMOf(campaignId) || isMemberOf(campaignId);
        allow create, update, delete: if isDMOf(campaignId);

        // ── Tokens (sous-collection — CHANTIER D nuit 3) ────────
        // Tokens vivent en sous-collection pour borner le coût des writes
        // individuels (un déplacement = un write). Read pour tous les
        // membres ; write pour le MJ uniquement à ce stade (V1). Les
        // joueurs déplacent leur token via le MJ — l'autorisation de
        // self-write par PJ viendra avec un check `linkedCharacterId ==
        // ma propre fiche` en chantier ultérieur (plan map-phase3).
        //
        // Choix d'architecture : fog/lights/aoe restent INLINE sur le
        // doc `maps/{mid}` plutôt qu'en sous-collections. Justification :
        // ils sont peu fréquents (révélation manuelle, pose d'AoE) → la
        // granularité par-doc des sous-collections n'apporte pas de gain
        // mesurable et complique le service. Cf. `MapMeta` dans
        // `src/shared/types/map.ts`.
        match /tokens/{tokenId} {
          allow read: if isDMOf(campaignId) || isMemberOf(campaignId);
          allow create, update, delete: if isDMOf(campaignId);
        }
      }

      // ── Handouts (S3, plan 27) ────────────────────────────────
      match /handouts/{handoutId} {
        // Members can read handouts they are recipients of (or 'all')
        allow read: if isMemberOf(campaignId)
          && (isDMOf(campaignId)
              || resource.data.recipients == 'all'
              || request.auth.uid in resource.data.recipients);
        allow create, update, delete: if isDMOf(campaignId);
      }

      // ── NPCs (S3, plan 28) ────────────────────────────────────
      match /npcs/{npcId} {
        // Players read only NPCs visible to all; DM reads everything
        allow read: if isDMOf(campaignId)
          || (isMemberOf(campaignId) && resource.data.visibility == 'all');
        allow create, update, delete: if isDMOf(campaignId);
      }
    }

    function getMyCharacterIds(campaignId) {
      // JALON 4.0.2 : sous-collection renommée `members/`. Le doc member a
      // `characterId` (single character per campaign).
      // Returns a single-element list (or `[null]` si pas de fiche liée).
      return [get(/databases/$(database)/documents/campaigns/$(campaignId)/members/$(request.auth.uid)).data.characterId];
    }

    // ═══════════════════════════════════════════════════════════
    // /inviteCodes/{code}
    // ═══════════════════════════════════════════════════════════

    match /inviteCodes/{code} {
      // Read: any signed-in user (lookup by code when accepting an invite).
      allow read: if isSignedIn();

      // Create:
      //  - le code doit correspondre au doc ID (anti-spoof : on n'écrit pas un
      //    code différent du chemin sur lequel on le pose),
      //  - le createdBy doit être l'utilisateur courant,
      //  - l'utilisateur doit être MJ de la campagne référencée — soit dans
      //    l'état pré-batch (`isDMOf`), soit dans l'état post-batch via
      //    `getAfter()` (cas où le doc campaign est créé dans le MÊME batch,
      //    chemin nominal de `createCampaign` 4.0.3).
      // JALON 4.0.4 fix : avant ce fix, `createCampaign` cassait parce que
      // l'inviteCode était évalué AVANT que le campaign ne soit visible, donc
      // `isDMOf(campaignId)` retournait false (le doc n'existe pas pre-batch).
      // `getAfter()` lit l'état après le batch et révèle le campaign qui sera
      // committé dans la même opération atomique → la rule passe.
      allow create: if isSignedIn()
        && request.resource.data.code == code
        && request.resource.data.createdBy == request.auth.uid
        && (
          isDMOf(request.resource.data.campaignId)
          || request.auth.uid in
             getAfter(/databases/$(database)/documents/campaigns/$(request.resource.data.campaignId)).data.gmIds
        );

      // Update: MJ de la campagne référencée uniquement (rotation manuelle
      // hors-scope V1, mais la rule la prépare).
      allow update: if isDMOf(resource.data.campaignId);

      // Delete: MJ de la campagne référencée (révocation manuelle, ex. fuite).
      allow delete: if isDMOf(resource.data.campaignId);
    }

    // ═══════════════════════════════════════════════════════════
    // Public content (rarely used at runtime — most content bundled in app)
    // ═══════════════════════════════════════════════════════════

    match /publicContent/{document=**} {
      allow read: if true;
      allow write: if false;   // admin only via Admin SDK
    }

    // ═══════════════════════════════════════════════════════════
    // /publicStats/{slug} (S5, plan 39) — public no-auth read
    // ═══════════════════════════════════════════════════════════

    match /publicStats/{slug} {
      allow read: if true;
      allow write: if false;   // Cloud Function only via Admin SDK
    }

    match /publicStatsSlugs/{slug} {
      allow read: if true;
      allow write: if false;
    }

    // ═══════════════════════════════════════════════════════════
    // CollectionGroup queries — JALON 4.0.4
    // ═══════════════════════════════════════════════════════════
    //
    // Firestore Rules : une rule nichée `match /campaigns/{cid}/members/{uid}`
    // ne s'applique PAS aux requêtes `collectionGroup('members')`. Pour que
    // `listMyCampaigns` puisse exécuter Q2 (`collectionGroup('members') where
    // userId == auth.uid`), il faut une rule top-level qui matche les docs
    // `members` quel que soit le préfixe de chemin.
    //
    // L'autorisation est volontairement étroite : seul le user lui-même peut
    // lister SES propres docs members via collectionGroup — pas le DM qui
    // tente de lister tous les members de toutes les campagnes. La lecture
    // ciblée d'un member précis reste régie par la rule path-bound L201+
    // (`match /campaigns/{cid}/members/{uid}`) qui autorise les co-membres.
    match /{path=**}/members/{userId} {
      allow read: if isSignedIn()
        && resource.data.userId == request.auth.uid;
    }

    // ═══════════════════════════════════════════════════════════
    // Default deny
    // ═══════════════════════════════════════════════════════════

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
